# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application Variables
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
DATA_DIR=/path/to/data/directory
PORT=20128
BASE_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Gemini OAuth
GEMINI_OAUTH_CLIENT_ID=your-gemini-oauth-client-id
GEMINI_OAUTH_CLIENT_SECRET=your-gemini-oauth-client-secret

# Antigravity OAuth
ANTIGRAVITY_OAUTH_CLIENT_ID=your-antigravity-oauth-client-id
ANTIGRAVITY_OAUTH_CLIENT_SECRET=your-antigravity-oauth-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
